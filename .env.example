# GCP Project Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# GCP Resources
GCS_BUCKET=your-project-id-nlp-corpus
BQ_DATASET=nlp_demo

# Authentication — no key file needed.
# Run once locally: gcloud auth application-default login
# Optional SA impersonation:
# IMPERSONATE_SA=agentic-nlp-sa@your-project-id.iam.gserviceaccount.com
